# ============================================================
# AI Control Plane — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ============================================================

# --- Environment ---
ENVIRONMENT=development
# Options: development, staging, production

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/control_plane.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_control_plane

# --- Claude AI ---
CLAUDE_API_KEY=mock
# Set to your actual Anthropic API key when ready
# When set to "mock", the system uses intelligent mock responses

CLAUDE_MODEL=claude-sonnet-4-20250514
# Options: claude-sonnet-4-20250514, claude-3-5-sonnet-20241022, etc.

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# --- Authentication ---
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Logging ---
LOG_LEVEL=DEBUG
# Options: DEBUG, INFO, WARNING, ERROR

# --- Observability ---
TRACE_RETENTION_DAYS=30
METRICS_ENABLED=true

# --- Policy ---
POLICY_FILE=config.yaml
